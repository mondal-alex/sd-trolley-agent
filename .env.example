# Copy this file to `.env` and fill in your values.
# `.env` is gitignored so your secrets stay local.

# --- Ollama (local LLM) ---
# Tool-calling-capable model pulled via `ollama pull <model>`.
OLLAMA_MODEL=llama3.1
# Default Ollama server URL.
OLLAMA_BASE_URL=http://localhost:11434

# --- Google Maps ---
# Used by the routing tools (Directions / Distance Matrix / Places).
# Create a key in Google Cloud Console and enable billing.
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
